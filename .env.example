# Recognition mode: mp4 | rtsp (CLI --source overrides this)
SOURCE=mp4

# Match threshold (0.0–1.0). 0.30 = 30%
THRESHOLD=0.30

# Paths
INPUT_DIR=input
OUTPUT_DIR=output
DATABASE_PATH=database/embeddings.pkl
STAFF_DIR=staff

# Shared RTSP credentials (used by cameras.yaml channel= entries)
RTSP_USERNAME=admin
RTSP_PASSWORD=your_password_here
RTSP_HOST=your_nvr_ip
RTSP_PORT=554

CAMERAS_FILE=cameras.yaml

RTSP_BUFFER_SIZE=1
RTSP_SKIP_BEFORE_RECONNECT=45
RTSP_RECONNECT_DELAY=2
RTSP_FFMPEG_OPTIONS=rtsp_transport;tcp|fflags;nobuffer+discardcorrupt|flags;low_delay|max_delay;500000|stimeout;5000000|rw_timeout;5000000

ONNX_PROVIDERS=cuda,cpu
SHOW_PREVIEW=1
SAVE_RTSP_OUTPUT=0

LOG_DIR=logs
CLIPS_DIR=output/staff_clips
STAFF_CLIP_POST_FRAMES=45
STAFF_CLIP_FPS=15

MIN_FACE_WIDTH=80
MIN_BLUR_SCORE=60
MAX_YAW_DEG=40
MAX_PITCH_DEG=30
MAX_ROLL_DEG=30
COLLECT_FRAMES=8
MIN_COLLECT_FRAMES=3
TOP_QUALITY_FRAMES=3
CONFIRM_VOTES=3
TRACK_IOU=0.25
TRACK_MAX_MISSES=45
MAX_EMBEDS_PER_PERSON=50
